# API 綁定位置。Docker 執行時請覆寫為 0.0.0.0。
API_HOST=127.0.0.1
API_PORT=8765
# CLI 連線位置，可指向 container 或遠端 API。
API_BASE_URL=http://127.0.0.1:8765
ANALYZE_POLL_INTERVAL_SECONDS=30

# 產出與暫存目錄。
OUTPUT_DIR=outputs
WORK_DIR=.work

# Analysis request 未提供 override 時使用的候選預設值。
DEFAULT_CANDIDATE_COUNT=2
DEFAULT_MIN_DURATION_MINUTES=8
DEFAULT_MAX_DURATION_MINUTES=12

# OpenAI 金鑰不得留空或使用此範例值。
OPENAI_API_KEY=replace-me
# 相容 OpenAI API 的自訂端點；使用官方端點時留空。
OPENAI_BASE_URL=

# 文字判斷預設模型；空白的專用模型會回退至 LLM_MODEL。
LLM_MODEL=gpt-5.4-mini
CURATOR_MODEL=
TRANSLATION_MODEL=
METADATA_MODEL=

# 語音轉錄：openai 或 local。
TRANSCRIPTION_PROVIDER=openai
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_MAX_UPLOAD_MB=8
OPENAI_TRANSCRIPTION_MAX_ATTEMPTS=3
OPENAI_TRANSCRIPTION_RETRY_SLEEP_SECONDS=0
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=auto

# 媒體工具與輸出品質。
FFMPEG_BIN=ffmpeg
YTDLP_JS_RUNTIME=node
VIDEO_MAX_HEIGHT=1080
VIDEO_CRF=18
SUBTITLE_CHINESE_FONT_SIZE=72
SUBTITLE_ENGLISH_FONT_SIZE=60

# 外部請求重試與逾時。
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_SLEEP_SECONDS=10
